					"back_right_leg.tx": " -4.5",
					"front_left_leg.ty": " 22 +clamp(if(limb_speed>=if(is_child, 0.7, 0.87), -2*limb_speed +cos(           var.ls_2)*2*if(is_child, 1.2, 1)*limb_speed, -2*limb_speed -cos(          var.ls)*2*clamp(limb_speed*6, 0, 1) ), -4, 0) +var.attack*4",
					"front_right_leg.ty": "22 +clamp(if(limb_speed>=if(is_child, 0.7, 0.87), -2*limb_speed +cos(torad( 45)+var.ls_2)*2*if(is_child, 1.2, 1)*limb_speed, -2*limb_speed +cos(          var.ls)*2*clamp(limb_speed*6, 0, 1) ), -4, 0) +var.attack*4",
					"back_left_leg.ty": "  22 +clamp(if(limb_speed>=if(is_child, 0.7, 0.87), -2*limb_speed +sin(           var.ls_2)*2*if(is_child, 1.2, 1)*limb_speed, -2*limb_speed +sin(torad(23)+var.ls)*2*clamp(limb_speed*6, 0, 1) ), -4, 0)",
					"back_right_leg.ty": " 22 +clamp(if(limb_speed>=if(is_child, 0.7, 0.87), -2*limb_speed +sin(torad( 45)+var.ls_2)*2*if(is_child, 1.2, 1)*limb_speed, -2*limb_speed -sin(torad(23)+var.ls)*2*clamp(limb_speed*6, 0, 1) ), -4, 0)",
