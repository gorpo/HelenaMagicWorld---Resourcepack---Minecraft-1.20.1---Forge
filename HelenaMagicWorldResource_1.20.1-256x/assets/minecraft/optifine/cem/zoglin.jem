			"animations": [
				{
					"var.r": "random(id)*pi*4",
					"var.ls": "  limb_swing/if(is_child, 1.8, 1.2)",
					"var.ls_2": "limb_swing/if(is_child, 2.2, 1.2)",
					"var.b": "var.r +age/if(is_child, 6, 10)",
					"var.attack": "(head.rx-torad(50))",
					"var.sniff": "clamp(-2 +sin(var.r +age/60)*3, 0, 1)"
				},
				{
					"body.rx": "torad(-3)                       +if(limb_speed>=if(is_child, 0.7, 0.87), -sin(torad(20)+var.ls_2)/10*limb_speed, sin(var.ls*2)/30*clamp(limb_speed*6, 0, 1) ) +cos(var.r+age*if(is_child, 1.5, 1)/12)/60 +var.attack/5",
					"body.ry": "clamp(torad(head_yaw)/5, torad(-15), torad(15))*clamp(1-limb_speed*2, 0, 1) +sin(torad(-45)+var.r+age/16)/8*var.sniff*clamp(1-limb_speed*2, 0, 1)",
					"body.rz": "                                 if(limb_speed>=if(is_child, 0.7, 0.87), cos(torad(-60)+var.ls_2)/20, sin(torad(-60)+var.ls  )/14*clamp(limb_speed*6, 0, 1) )",
					"body.tx": "-sin(torad(-45)+var.r+age/16)*var.sniff*clamp(1-limb_speed*2, 0, 1)",
					"body.ty": "7 -limb_speed +sin(var.r+age*if(is_child, 1.5, 1)/12 +cos(var.r+age*if(is_child, 1.5, 1)/12)/2)/4 +var.attack*2",
					"body.tz": "-var.attack",
					"head2.rx": "torad(50) +torad(head_pitch)/3 +if(limb_speed>=if(is_child, 0.7, 0.87), -cos(var.ls_2)/8, -cos(var.ls*2)/30*clamp(limb_speed*6, 0, 1) ) -body.rx*if(limb_speed>=if(is_child, 0.7, 0.87), 1, 0.5) +sin(var.r+age*if(is_child, 1.5, 1)/12)/40 +(-torad(10) +sin(var.r+age)/40*cos(var.r+age/6))*var.sniff*clamp(1-limb_speed*2, 0, 1) +var.attack",
					"head2.ry": "          clamp( torad(head_yaw)/1.5*(1-var.sniff) +sin(var.r+age/16 +sin(torad(45)+var.r+age/8)/3)/3*var.sniff*clamp(1-limb_speed*2, 0, 1), torad(-60), torad(60))",
					"head2.rz": "-body.rz +clamp(-torad(head_yaw)/6  *(1-var.sniff) +sin(var.r+age/16 +sin(torad(45)+var.r+age/8)/3)/4*var.sniff*clamp(1-limb_speed*2, 0, 1), torad(-10), torad(10)) -var.attack/6*torad(head_yaw)",
					"head2.tx": "          clamp(-torad(head_yaw)*3, -3, 3)*(1-var.sniff) -var.attack*3*torad(head_yaw)",
					"head2.ty": "-21  +if(is_child, -6, 0)     +if(limb_speed>=if(is_child, 0.7, 0.87), -1*limb_speed -sin(var.ls_2)*limb_speed, 0) -var.attack*if(is_child, 6, 3)",
					"head2.tz": "-8.5 +if(is_child, 2, 0)",
					"head2.sx": "if(is_child, 1.2, 1)",
					"head2.sy": "if(is_child, 1.2, 1)",
					"head2.sz": "if(is_child, 1.2, 1)",
					"snout.rx": "clamp((-torad(3) +sin(var.r+age/1.3)/20)*var.sniff*clamp(1-limb_speed*2, 0, 1) +(-torad(3) +sin(age/1.3+var.r)/20)*clamp(-head_pitch -2 +sin(age/19+var.r)*3 -cos(age/33+var.r)*3, 0, 1-var.sniff), -1, 0)"
				},
				{
					"front_left_leg.rx": " if(limb_speed>=if(is_child, 0.7, 0.87),  sin(           var.ls_2)/2  *if(is_child, 1.2, 1)*limb_speed +clamp(-cos(           var.ls_2)/2, 0, torad( 30))*limb_speed, -sin(          var.ls)/4   +clamp( cos(          var.ls)/2, 0, torad( 40))*clamp(limb_speed*6, 0, 1) ) +torad(2) +sin(var.r+age*if(is_child, 1.5, 1)/12 +cos(var.r+age*if(is_child, 1.5, 1)/12)/2)/40 -var.attack/2",
					"front_right_leg.rx": "if(limb_speed>=if(is_child, 0.7, 0.87),  sin(torad( 45)+var.ls_2)/2  *if(is_child, 1.2, 1)*limb_speed +clamp(-cos(torad( 45)+var.ls_2)/2, 0, torad( 30))*limb_speed,  sin(          var.ls)/4   +clamp(-cos(          var.ls)/2, 0, torad( 40))*clamp(limb_speed*6, 0, 1) ) +torad(2) +sin(var.r+age*if(is_child, 1.5, 1)/12 +cos(var.r+age*if(is_child, 1.5, 1)/12)/2)/40 -var.attack/2",
					"back_left_leg.rx": "  if(limb_speed>=if(is_child, 0.7, 0.87), -cos(           var.ls_2)/1.3*if(is_child, 1.2, 1)*limb_speed +clamp( sin(           var.ls_2)/2, torad(-30), 0)*limb_speed, -cos(torad(23)+var.ls)/2.3 +clamp( sin(torad(23)+var.ls)/3, torad(-30), 0)*clamp(limb_speed*6, 0, 1) ) -torad(2) -sin(var.r+age*if(is_child, 1.5, 1)/12 +cos(var.r+age*if(is_child, 1.5, 1)/12)/2)/40",
					"back_right_leg.rx": " if(limb_speed>=if(is_child, 0.7, 0.87), -cos(torad( 45)+var.ls_2)/1.3*if(is_child, 1.2, 1)*limb_speed +clamp( sin(torad( 45)+var.ls_2)/2, torad(-30), 0)*limb_speed,  cos(torad(23)+var.ls)/2.3 +clamp(-sin(torad(23)+var.ls)/3, torad(-30), 0)*clamp(limb_speed*6, 0, 1) ) -torad(2) -sin(var.r+age*if(is_child, 1.5, 1)/12 +cos(var.r+age*if(is_child, 1.5, 1)/12)/2)/40",
					"front_left_leg.ry": " clamp(torad(-10)+limb_speed-0.4, torad(-10), torad(-5))",
					"front_right_leg.ry": "clamp(torad( 10)-limb_speed+0.4, torad( 5), torad( 10))",
					"back_left_leg.ry": "  torad( 5)",
					"back_right_leg.ry": " torad(-5)",
					"front_left_leg.rz": " clamp(-torad(head_yaw)/5, torad(-15), torad(15))*clamp(1-limb_speed*2, 0, 1) -sin(torad(-45)+var.r+age/16)/5*var.sniff*clamp(1-limb_speed*2, 0, 1)",
					"front_right_leg.rz": "clamp(-torad(head_yaw)/5, torad(-15), torad(15))*clamp(1-limb_speed*2, 0, 1) -sin(torad(-45)+var.r+age/16)/5*var.sniff*clamp(1-limb_speed*2, 0, 1)",
					"back_left_leg.rz": "  clamp( torad(head_yaw)/5, torad(-15), torad(15))*clamp(1-limb_speed*2, 0, 1)",
					"back_right_leg.rz": " clamp( torad(head_yaw)/5, torad(-15), torad(15))*clamp(1-limb_speed*2, 0, 1)",
