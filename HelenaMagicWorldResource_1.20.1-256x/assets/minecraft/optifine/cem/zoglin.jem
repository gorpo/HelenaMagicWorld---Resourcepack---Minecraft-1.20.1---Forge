					"front_right_leg.tz": "-8.5 +if(limb_speed>=if(is_child, 0.7, 0.87),  sin(torad( 45)+var.ls_2)*6*if(is_child, 1.2, 1)*limb_speed,  sin(          var.ls)*4) -var.attack*4",
