{
    "multipart": [
        {   "when": { "bites": "0" },
            "apply": [
                { "model": "block/cake", "weight": 2 },
                { "model": "block/cake_c", "weight": 1 },
                { "model": "block/cake_b", "weight": 1 }
            ]
        },
        {   "when": { "bites": "1" },
            "apply": [
                { "model": "block/cake_slice1", "weight": 2 },
                { "model": "block/cake_slice1_c", "weight": 1 },
                { "model": "block/cake_slice1_b", "weight": 1 }
            ]
        },
        {   "when": { "bites": "2" },
