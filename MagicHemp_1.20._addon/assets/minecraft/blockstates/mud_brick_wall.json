{
  "multipart": [
    {
      "when": { "up": "true" },
      "apply": {
        "model": "block/mud_brick_wall_post"
      }
    },
    {
      "when": { "north": "low" },
      "apply": {
        "model": "block/mud_brick_wall_side", "uvlock": true
      }
    },
    {
      "when": { "east": "low" },
      "apply": {
        "model": "block/mud_brick_wall_side", "y": 90, "uvlock": true
      }
    },
    {
      "when": { "south": "low" },
      "apply": {
        "model": "block/mud_brick_wall_side", "y": 180, "uvlock": true
      }
    },
    {
      "when": { "west": "low" },
      "apply": {
        "model": "block/mud_brick_wall_side", "y": 270, "uvlock": true
      }
    },
    {
      "when": { "north": "tall" },
      "apply": {
        "model": "block/mud_brick_wall_side_tall", "uvlock": true
      }
    },
    {
      "when": { "east": "tall" },
      "apply": {
        "model": "block/mud_brick_wall_side_tall", "y": 90, "uvlock": true
      }
    },
    {
      "when": { "south": "tall" },
      "apply": {
        "model": "block/mud_brick_wall_side_tall", "y": 180, "uvlock": true
      }
    },
    {
      "when": { "west": "tall" },
      "apply": {
        "model": "block/mud_brick_wall_side_tall", "y": 270, "uvlock": true
      }
    },
    {
      "when": { "north": "none", "south": "none", "east": "none", "west": "none", "up": "false" },
      "apply": [
        { "model": "block/pot1", "weight": 2 },
        { "model": "block/pot1", "y": 90, "weight": 2 },
        { "model": "block/pot1", "y": 180, "weight": 2 },
        { "model": "block/pot1", "y": 270, "weight": 2 },
        { "model": "block/pot2", "weight": 1 },
        { "model": "block/pot2", "y": 90, "weight": 1 },
        { "model": "block/pot2", "y": 180, "weight": 1 },
        { "model": "block/pot2", "y": 270, "weight": 1 },
        { "model": "block/pot3", "weight": 1 },
        { "model": "block/pot3", "y": 90, "weight": 1 },
        { "model": "block/pot3", "y": 180, "weight": 1 },
        { "model": "block/pot3", "y": 270, "weight": 1 }
      ]
    }
  ]
}