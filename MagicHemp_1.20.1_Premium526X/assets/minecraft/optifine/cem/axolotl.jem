			],
			"animations": [
				{
					"var.a": "0",
					"var.r": "random(id)*pi*4",
					"var.ls": "limb_swing/if(is_child, 2, 1)",
					"var.b1": "var.r+age/if(is_child, 8, 12)",
					"var.b2": "var.r+age/if(is_child, 3, 5)",
					"var.b3": "var.r+age/if(is_child, 6, 9)"
				},
				{
					"body.rx": "0",
					"body.ry": "0",
					"body.rz": "0",
					"body.tx": "0",
					"body.ty": "0",
					"body.tz": "0",
					"body2.rx": "if(is_in_water, (-torad(15) +cos(var.b1)/20)*clamp(1-limb_speed*10, 0, 1) +torad(head_pitch)*clamp(limb_speed*2, 0, 1), ( cos(pi/8+var.b2)/80 )*clamp(1-limb_speed*10, 0, 1) )",
					"body2.ry": "if(is_in_water,-cos(     var.ls/1.2)/6 *clamp(limb_speed*2, 0, 1) +if(age>4, clamp(-(rot_y-var.tilt), -pi/2, pi/2)/4, 0), -cos(var.ls*2)/10)",
					"body2.rz": "if(is_in_water, sin(pi/4+var.ls/1.2)/12*clamp(limb_speed*3, 0, 1) +( sin(var.b1)/4 +sin(var.b3)/6 )/4*clamp(1-limb_speed*10, 0, 1) -if(age>4, clamp(rot_y-var.tilt, -pi/3, pi/3)/1.5*2, 0), cos(-pi/4+var.ls*2)/10)",
					"body2.tx": "if(is_in_water,-cos(pi/4+var.ls/1.2)   *clamp(limb_speed*2, 0, 1), -cos(pi/4+var.ls*2))",
					"body2.ty": "if(is_in_water, sin(var.b1 -sin(var.b1)/2)/2*clamp(1-limb_speed*10, 0, 1) +clamp(limb_speed*10, 0, 1)/2, 1.75 +( cos(var.b2)/8 )*clamp(1-limb_speed*10, 0, 1) ) +20 -6",
					"body2.tz": "-1",
					"head2.rx": "if(is_in_water, -cos(var.b1)/30*clamp(1-limb_speed*10, 0, 1) +torad(head_pitch), torad(head_pitch) -torad(5) +( torad(5) -cos(-pi/4+var.b2)/40 )*clamp(1-limb_speed*10, 0, 1) +if(is_child, -torad(5), 0) )",
					"head2.ry": "if(is_in_water, torad(head_yaw)*cos(torad(head_pitch)) +sin(-pi/8+var.ls/1.2)/10*clamp(limb_speed*3, 0, 1) +if(age>4, clamp(rot_y-var.tilt, -pi/4, pi/4)    , 0), -body2.ry -cos(pi/4+var.ls*2)/6 +torad(head_yaw))",
					"head2.rz": "if(is_in_water, torad(head_yaw)*sin(torad(head_pitch)) +cos(pi/4+var.ls/1.2)/16 *clamp(limb_speed*3, 0, 1) -if(age>4, clamp(rot_y-var.tilt, -pi/3, pi/3)/3*2, 0),            cos(pi/4+var.ls*2)/6                 )",
					"head2.tx": "if(is_in_water, -cos(pi/3+var.ls/1.2)/1.5*clamp(limb_speed*2, 0, 1), -cos(pi/3+var.ls*2)/1.2)",
					"head2.ty": "if(is_in_water, ( sin(torad(head_pitch))*4 -0.5)/4 +(sin(var.b1 -sin(var.b1)/2)/2 -1.5)*clamp(1-limb_speed*10, 0, 1), if(is_child, -clamp(limb_speed*10, 0, 1), 0) +clamp(limb_speed*10, 0, 1) +cos(var.b2)/6*clamp(1-limb_speed*10, 0, 1)) +15",
					"head2.tz": "if(is_in_water, (-cos(torad(head_pitch))*4 +4)/4 +0.2*clamp(1-limb_speed*10, 0, 1), 0) -5",
					"head2.sx": "if(is_child, 1.2, 1)",
					"head2.sy": "head2.sx",
					"head2.sz": "head2.sx"
				},
				{
					"front_left_leg.rx": " if(is_in_water, -torad( 5) +torad(80)*clamp(-1+limb_speed*3, 0, 1) +( cos(var.ls/1.2 -sin(var.ls/1.2)/2)           )*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) +cos(var.ls/1.2)/8*clamp(limb_speed*3, 0, 1), 0)",
					"front_right_leg.rx": "if(is_in_water, -torad( 5) +torad(80)*clamp(-1+limb_speed*3, 0, 1) +(-cos(var.ls/1.2 +sin(var.ls/1.2)/2)           )*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) -cos(var.ls/1.2)/8*clamp(limb_speed*3, 0, 1), 0)",
					"back_left_leg.rx": "  if(is_in_water,  torad(45) +torad(30)*clamp(-1+limb_speed*3, 0, 1) +(-cos(var.ls/1.2 +sin(var.ls/1.2)/2) -torad(20))*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) -sin(var.ls/1.2)/8*clamp(limb_speed*3, 0, 1) +(-cos(var.ls/2)/3 -cos(var.b3)/4 )/1.5*clamp(1-limb_speed*10, 0, 1), 0)",
					"back_right_leg.rx": " if(is_in_water,  torad(45) +torad(30)*clamp(-1+limb_speed*3, 0, 1) +( cos(var.ls/1.2 -sin(var.ls/1.2)/2) -torad(20))*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) +sin(var.ls/1.2)/8*clamp(limb_speed*3, 0, 1) +( cos(var.ls/2)/3 +cos(var.b3)/4 )/1.5*clamp(1-limb_speed*10, 0, 1), 0)",
					"front_left_leg.ry": " if(is_in_water, -torad(20) +torad(30)*clamp(-1+limb_speed*3, 0, 1) +(                                     torad(30))*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) -sin(var.b1 -sin(var.b1)/2)/3*clamp(1-limb_speed*10, 0, 1) -body.ry, 0)",
					"front_right_leg.ry": "if(is_in_water,  torad(20) -torad(30)*clamp(-1+limb_speed*3, 0, 1) +(                                    -torad(30))*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) +sin(var.b1 -sin(var.b1)/2)/3*clamp(1-limb_speed*10, 0, 1) -body.ry, 0)",
					"back_left_leg.ry": "  if(is_in_water,  torad(40) -torad(35)*clamp(-1+limb_speed*3, 0, 1) +(                                    -torad(20))*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) +( cos(var.b1)/3 +cos(var.b3)/4 )*clamp(1-limb_speed*10, 0, 1) -body.ry/2, 0)",
					"back_right_leg.ry": " if(is_in_water, -torad(40) +torad(35)*clamp(-1+limb_speed*3, 0, 1) +(                                     torad(20))*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) +( cos(var.b1)/3 +cos(var.b3)/4 )*clamp(1-limb_speed*10, 0, 1) -body.ry/2, 0)",
					"front_left_leg.rz": " if(is_in_water, -torad(20) +torad(30)*clamp(-1+limb_speed*3, 0, 1) +(-sin(var.ls/1.2)/2                            )*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) -sin(pi/5 +var.b1 -sin(pi/6 +var.b1))/2*clamp(1-limb_speed*10, 0, 1), 0)",
					"front_right_leg.rz": "if(is_in_water,  torad(20) -torad(30)*clamp(-1+limb_speed*3, 0, 1) +(-sin(var.ls/1.2)/2                            )*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)) +sin(pi/4 +var.b1 -sin(      var.b1))/2*clamp(1-limb_speed*10, 0, 1), 0)",
					"back_left_leg.rz": "  if(is_in_water, -torad(20) +torad(15)*clamp(-1+limb_speed*3, 0, 1) +( sin(var.ls/1.2)/2                            )*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)), 0)",
					"back_right_leg.rz": " if(is_in_water,  torad(20) -torad(15)*clamp(-1+limb_speed*3, 0, 1) +( sin(var.ls/1.2)/2                            )*clamp(limb_speed*6, 0, 1-clamp(-1+limb_speed*3, 0, 1)), 0)",
					"front_left_leg.tx": " if(is_in_water,  clamp(-1+limb_speed*3, 0, 1)/4, 0) +2.75",
					"front_right_leg.tx": "if(is_in_water, -clamp(-1+limb_speed*3, 0, 1)/4, 0) -2.75",
					"back_left_leg.tx": "  if(is_in_water,  clamp(-1+limb_speed*3, 0, 1)/4, 0) +2.75",
					"back_right_leg.tx": " if(is_in_water, -clamp(-1+limb_speed*3, 0, 1)/4, 0) -2.75",
					"front_left_leg.sx": " if(!is_in_water, 0, if(is_child, 1.2, 1))",
					"front_left_leg.sy": " front_left_leg.sx",
					"front_left_leg.sz": " front_left_leg.sx",
					"front_right_leg.sx": "front_left_leg.sx",
					"front_right_leg.sy": "front_left_leg.sx",
					"front_right_leg.sz": "front_left_leg.sx",
					"back_left_leg.sx": "  front_left_leg.sx",
					"back_left_leg.sy": "  front_left_leg.sx",
					"back_left_leg.sz": "  front_left_leg.sx",
					"back_right_leg.sx": " front_left_leg.sx",
					"back_right_leg.sy": " front_left_leg.sx",
					"back_right_leg.sz": " front_left_leg.sx"
				},
				{
					"leg5.rx": "-torad(30) +cos(var.ls*2)/pi*1.5*1.3*clamp(limb_speed*20, 0.5, 1)",
					"leg7.rx": "-torad(30) -cos(var.ls*2)/pi*1.5*1.3*clamp(limb_speed*20, 0.5, 1)",
					"leg6.rx": " torad(20) -cos(var.ls*2)/pi*1.5*1.3*clamp(limb_speed*20, 0.5, 1)",
					"leg8.rx": " torad(20) +cos(var.ls*2)/pi*1.5*1.3*clamp(limb_speed*20, 0.5, 1)",
					"leg5.ry": "-body2.rx",
					"leg7.ry": "-body2.rx",
					"leg6.ry": "-body2.rx",
					"leg8.ry": "-body2.rx",
					"leg5.rz": "-torad(82) +(-cos( pi/14+var.b2)/14/3 )*clamp(1-limb_speed*10, 0, 1) +clamp(-sin(var.ls*2)/1.5*clamp(limb_speed*20, 0, 1), -1, 0) -body2.rz*1.5 -cos(var.ls*2)/15*clamp(limb_speed*20, 0, 1)",
					"leg7.rz": " torad(82) +( cos( pi/14+var.b2)/14/3 )*clamp(1-limb_speed*10, 0, 1) +clamp(-sin(var.ls*2)/1.5*clamp(limb_speed*20, 0, 1),  0, 1) -body2.rz*1.5 -cos(var.ls*2)/15*clamp(limb_speed*20, 0, 1)",
					"leg6.rz": "-torad(82) +(-cos(-pi/12+var.b2)/17/3 )*clamp(1-limb_speed*10, 0, 1) +clamp( sin(var.ls*2)/1.5*clamp(limb_speed*20, 0, 1), -1, 0) -body2.rz*1.5 -sin(var.ls*2)/15*clamp(limb_speed*20, 0, 1)",
					"leg8.rz": " torad(82) +( cos(-pi/12+var.b2)/17/3 )*clamp(1-limb_speed*10, 0, 1) +clamp( sin(var.ls*2)/1.5*clamp(limb_speed*20, 0, 1),  0, 1) -body2.rz*1.5 -sin(var.ls*2)/15*clamp(limb_speed*20, 0, 1)",
