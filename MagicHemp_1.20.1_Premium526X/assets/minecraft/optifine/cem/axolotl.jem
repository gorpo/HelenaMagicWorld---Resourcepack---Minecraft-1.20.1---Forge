					"leg6.tz": " 5.2 -cos(var.ls*2)/pi -1.5",
					"leg8.tz": " 5.2 +cos(var.ls*2)/pi -1.5",
					"leg8.sx": "if(!is_in_water, if(is_child, 1.2, 1), 0)",
