				},
				{
					"top_fern.rx": "   if(is_in_water, -torad(40) +sin(limb_swing/3 +var.b3 +cos(pi/2 +limb_swing/3 +var.b3))/2 *clamp(1-limb_speed, 0, 1) -torad(30)*clamp(limb_speed, 0, 1) -sin(var.ls/1.2)/10*clamp(limb_speed*3, 0, 1), -torad(80) +(-sin(var.b2)/20 )*clamp(1-limb_speed*10, 0, 1) -torad(head_pitch)/1.5)",
					"left_fern.rx": "  if(is_in_water, -torad( 5) +sin(limb_swing/3 +var.b3 +cos(pi/4 +limb_swing/3 +var.b3))/16*clamp(1-limb_speed, 0, 1) -torad( 8)*clamp(limb_speed, 0, 1)                                              , -torad(20) +(-sin(var.b2)/40 )*clamp(1-limb_speed*10, 0, 1))",
					"right_fern.rx": " if(is_in_water, -torad( 5) +sin(limb_swing/3 +var.b3 +cos(pi/4 +limb_swing/3 +var.b3))/16*clamp(1-limb_speed, 0, 1) -torad( 8)*clamp(limb_speed, 0, 1)                                              , -torad(20) +(-sin(var.b2)/40 )*clamp(1-limb_speed*10, 0, 1))",
					"left_fern2.ry": " if(is_in_water,  torad(40) -sin(limb_swing/3 +var.b3 +cos(pi/4 +limb_swing/3 +var.b3))/2 *clamp(1-limb_speed, 0, 1) +torad(40)*clamp(limb_speed, 0, 1) -cos(var.ls/1.2)/10*clamp(limb_speed*3, 0, 1) +if(age>4, clamp(-(rot_y-var.tilt), -pi/2, pi/2)/2, 0),  torad(80))",
					"right_fern2.ry": "if(is_in_water, -torad(40) +sin(limb_swing/3 +var.b3 +cos(pi/4 +limb_swing/3 +var.b3))/2 *clamp(1-limb_speed, 0, 1) -torad(40)*clamp(limb_speed, 0, 1) -cos(var.ls/1.2)/10*clamp(limb_speed*3, 0, 1) +if(age>4, clamp(-(rot_y-var.tilt), -pi/2, pi/2)/2, 0), -torad(80))",
					"tail2.rx": "      if(is_in_water, sin(var.b1 -sin(var.b1)/2)/12*clamp(1-limb_speed*10, 0, 1), (-cos(pi/12+var.b2)/80 )*clamp(1-limb_speed*10, 0, 1)          -torad(5) +cos(     var.ls*2*2)/8)",
					"tail2.ry": "clamp(if(is_in_water, -sin(     var.ls/1.2)/2*clamp(limb_speed*2, 0, 1) +( -sin(     var.b1)/4 +sin(var.b3)/6 )*clamp(1-limb_speed*10, 0, 1) +if(age>4, -(rot_y-var.tilt), 0), -sin(     var.ls*2)/2), -pi/2.5, pi/2.5)",
					"tail2.rz": "      if(is_in_water, -cos(pi/4+var.ls/1.2)/4*clamp(limb_speed*2, 0, 1) +( -cos(pi/4+var.b1)/4 +sin(var.b3)/6 )*clamp(1-limb_speed*10, 0, 1)                                 , -cos(pi/4+var.ls*2)/4)",
