					"leg2.tz": " 7.5 +if(!is_on_ground&&is_in_water, -sin(var.swim)*6, (sin(torad(-90     ) +var.ls)*6 *limb_speed)*var.run +(sin(torad( 90 +20) +var.ls)*10.5*clamp(limb_speed, 0.2, 1))*var.walk )",
					"leg3.tz": "-5.5 +if(!is_on_ground&&is_in_water, -sin(var.swim)*6, (sin(torad( 90     ) +var.ls)*6 *limb_speed)*var.run +(sin(torad(180    ) +var.ls)*10.5*clamp(limb_speed, 0.2, 1))*var.walk )",
