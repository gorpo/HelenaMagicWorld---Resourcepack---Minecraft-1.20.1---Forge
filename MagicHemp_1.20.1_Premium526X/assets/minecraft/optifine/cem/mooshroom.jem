					"var.swim": "limb_swing/2 +age/15*pi*2",
					"var.run": "clamp(if(limb_speed>=if(is_child, 0.52, 0.62), min(40, var.run +0.05 *frame_time*40), max(0, var.run -0.05 *frame_time*40)), 0, if(is_child, 1.3, 1))",
