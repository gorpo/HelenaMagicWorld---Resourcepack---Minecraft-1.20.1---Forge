					"right_ear.rz": "-torad(10) +sin(torad(-45)+var.b)/15 +( sin(torad(-90)+var.ls)/4 *limb_speed)*var.run +(-sin(torad(-135)+var.ls/0.5)/6*limb_speed)*var.walk -torad(head_yaw)/3 +clamp((-47 +sin(          var.r+age/26*2)*48)*clamp(-32 +cos(          (var.r+age/26)/1.5)*40 +cos(          (var.r+age/26)/4)*40, 0, 1), 0, 1)/2",
