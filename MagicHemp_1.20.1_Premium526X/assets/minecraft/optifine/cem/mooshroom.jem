				},
				{
					"head2.rx": "torad(head_pitch)/1.2 -if(!is_on_ground&&is_in_water, torad(-5) -cos(var.swim)/10, (-sin(var.ls)/6*limb_speed)*var.run +(sin(var.ls/0.5)/14*limb_speed)*var.walk ) +torad(-90) +sin(var.b+torad(90))/70 +(torad(-5)*limb_speed)",
