					"leg3.tx": " 3.4 +if(!is_on_ground&&is_in_water,  1, 0)",
					"leg4.tx": "-3.4 +if(!is_on_ground&&is_in_water, -1, 0)",
					"leg1.ty": "24 +if(!is_on_ground&&is_in_water, 4.5 +sin(torad( 90)+var.swim), clamp((-2*limb_speed +sin(torad( 90-22.5) +var.ls)*3 *limb_speed)*var.run +(sin(torad( 0  +20) +var.ls)*3 *limb_speed*1.2)*var.walk, -4, 0))",
					"leg2.ty": "24 +if(!is_on_ground&&is_in_water, 4.5 +sin(torad(-90)+var.swim), clamp((-2*limb_speed +sin(torad( 0      ) +var.ls)*3 *limb_speed)*var.run +(sin(torad(180 +20) +var.ls)*3 *limb_speed*1.2)*var.walk, -4, 0))",
					"leg3.ty": "24 +if(!is_on_ground&&is_in_water, 2.1 +sin(torad(-90)+var.swim), clamp((-2*limb_speed +sin(torad(180     ) +var.ls)*3 *limb_speed)*var.run +(sin(torad(-90    ) +var.ls)*3 *limb_speed*1.2)*var.walk, -4, 0))",
