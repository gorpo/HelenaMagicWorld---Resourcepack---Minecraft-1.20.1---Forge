					"head2.tx": "clamp(-torad(head_yaw)*2, -4, 4)",
					"head2.tz": " 3 +if(is_child, -1, 0) +if(!is_on_ground&&is_in_water, -3 -sin(var.swim), (sin(torad(45)+var.ls)*2*limb_speed)*var.run +(-1.5*limb_speed +sin(var.ls/0.5)* limb_speed)*var.walk ) +sin(var.b)/6",
					"head2.ty": "-28.5 -2 +if(!is_on_ground&&is_in_water, 1 -sin(var.swim)/2, (sin(torad(45)+var.ls)*limb_speed)*var.run )",
					"head2.sx": "if(is_child, 1.35, 1)",
					"head2.sy": "head2.sx",
					"head2.sz": "head2.sx",
					"horns.sx": "if(is_child, 0, 1)",
					"horns.sy": "horns.sx",
					"horns.sz": "horns.sx",
					"rotation.rx": "if(!is_on_ground&&is_in_water, torad(-10) +sin(var.swim)/15, (-sin(var.ls)/12*limb_speed -sin(torad(90)+var.ls)/8*limb_speed)*var.run +(-cos(var.ls*2)/16*limb_speed)*var.walk ) +sin(var.b-torad(90))/60",
					"rotation.ry": "(-sin(var.ls)/24*limb_speed)*var.run +(-sin(var.ls)/24*limb_speed)*var.walk",
					"rotation.rz": "-torad(head_yaw)/5",
					"rotation.tx": "(sin(var.ls)/3 *limb_speed)*var.walk",
					"rotation.ty": "if(!is_on_ground&&is_in_water,  0, (               sin(torad(-135)+var.ls/0.5)/4*limb_speed)*var.walk ) -19",
					"rotation.tz": "if(!is_on_ground&&is_in_water, -5, (-2*limb_speed +sin(            var.ls/0.5)  *limb_speed)*var.walk ) -4.5 +sin(var.b)/6"
				},
				{
					"leg1.rx": " sin(var.b)/30           +if(!is_on_ground&&is_in_water,  sin(var.swim)/2, (sin(torad( 0 -22.5) +var.ls)/2 *limb_speed*1.2)*var.run +(sin(torad(-90 +20) +var.ls)*clamp(limb_speed, 0.2, 1))*var.walk ) +torad(head_yaw)/12",
					"leg2.rx": " sin(var.b)/30           +if(!is_on_ground&&is_in_water, -sin(var.swim)/2, (sin(torad(-90     ) +var.ls)/2 *limb_speed*1.2)*var.run +(sin(torad( 90 +20) +var.ls)*clamp(limb_speed, 0.2, 1))*var.walk ) -torad(head_yaw)/12",
					"leg3.rx": "-sin(var.b)/30 -torad(2) +if(!is_on_ground&&is_in_water, -sin(var.swim)/2, (sin(torad( 90     ) +var.ls)/2 *limb_speed*1.2)*var.run +(sin(torad(180    ) +var.ls)*clamp(limb_speed, 0.2, 1))*var.walk ) +torad(head_yaw)/12",
					"leg4.rx": "-sin(var.b)/30 -torad(2) +if(!is_on_ground&&is_in_water,  sin(var.swim)/2, (sin(torad(180-22.5) +var.ls)/2 *limb_speed*1.2)*var.run +(sin(torad( 0     ) +var.ls)*clamp(limb_speed, 0.2, 1))*var.walk ) -torad(head_yaw)/12",
					"leg1.ry": "clamp(torad( 5)-limb_speed, 0, torad( 5)) +torad(head_yaw)/5",
					"leg2.ry": "clamp(torad(-5)+limb_speed, torad(-5), 0) +torad(head_yaw)/5",
					"leg3.ry": "clamp(torad(-5)+limb_speed, torad(-5), 0) +torad(head_yaw)/5",
